# Copy to .env and fill in values before running.
# .env is gitignored — never commit real credentials.

# ── Database passwords ────────────────────────────────────────────────────────
AUTH_DB_PASSWORD=postgres
REGISTRY_DB_PASSWORD=postgres
GATEWAY_DB_PASSWORD=postgres
AGENTCORE_DB_PASSWORD=postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
RSA_KEY_ID=key-2024-01
TOKEN_EXPIRE_MINUTES=60

# ── Seed account (used by connectivity-seeder and agentbe registry auth) ──────
SEED_USERNAME=sre-seed@example.com
SEED_PASSWORD=changeme

# ── GitHub PAT — required to pull AgentCore during image build ────────────────
GITHUB_TOKEN=ghp_...

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AGENT_LLM_MODEL=claude-sonnet-4-6

# ── SLMPlatform (agent run metrics + analytics) ──────────────────────────────
SLM_DB_PASSWORD=postgres
SLMPLATFORM_API_TOKEN=
AGENT_ID=chat-ai-agent

# ── Tool execution mode ───────────────────────────────────────────────────────
# true  = use pre-canned synthetic responses from RegistryService (no real APIs needed)
# false = make real AWS / Datadog / PagerDuty calls
USE_SYNTHETIC_DATA=true

# ── Real-stack credentials (only needed when USE_SYNTHETIC_DATA=false) ────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

DD_API_KEY=...
DD_APP_KEY=...
DD_SITE=datadoghq.com

PD_API_KEY=...
PD_ROUTING_KEY=...
PD_FROM_EMAIL=sre@example.com
PD_SERVICE_ID=PXXXXXX
