server {
    listen 80;

    # Use Docker's embedded DNS so upstream hostnames are re-resolved on each
    # request rather than cached at nginx startup (prevents stale-IP 502s after
    # container restarts/rebuilds).
    resolver 127.0.0.11 valid=10s ipv6=off;

    # ── React SPA ─────────────────────────────────────────────────────────────
    location = /index.html {
        root /usr/share/nginx/html;
        add_header Cache-Control "no-store, no-cache, must-revalidate";
        add_header Pragma "no-cache";
        expires 0;
    }
    location / {
        root /usr/share/nginx/html;
        try_files $uri $uri/ /index.html;
    }

    # ── AuthService — token endpoint bypasses AgentGateway entirely ─────────
    location = /gateway/auth/token {
        set $auth "${AUTH_SERVICE_URL}";
        rewrite ^/gateway/auth/token$ /auth/token break;
        proxy_pass $auth;
        proxy_buffering off;
        proxy_read_timeout 10s;
    }

    # ── Envoy sidecar — all agent API calls ──────────────────────────────────
    # /gateway/* → envoy:10000/* (Envoy handles JWT authn + OPA ext_authz)
    location /gateway/ {
        set $gw "${ENVOY_URL}";
        rewrite ^/gateway(/.*)$ $1 break;
        proxy_pass $gw;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Authorization $http_authorization;
        proxy_pass_header Authorization;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 120s;
    }

    # ── Remediation result poll — direct to sre-agent, no JWT required ─────────
    # Read-only Redis poll; no privileged operation. Bypasses Envoy so the
    # /remediation page works without the user being logged in on the same window.
    location = /sre-result {
        set $sre "${SRE_AGENT_URL}";
        proxy_pass $sre/remediation-result;
        proxy_set_header Host $proxy_host;
        proxy_read_timeout 5s;
    }

    location = /sre-result/clear {
        set $sre "${SRE_AGENT_URL}";
        proxy_method DELETE;
        proxy_pass $sre/remediation-result;
        proxy_set_header Host $proxy_host;
        proxy_read_timeout 5s;
    }

    # ── AgentControlPlane — live policy control API ──────────────────────────
    location /control/ {
        set $acp "${AGENT_CONTROL_PLANE_URL}";
        rewrite ^/control(/.*)$ $1 break;
        proxy_pass $acp;
        proxy_set_header Host $proxy_host;
        proxy_read_timeout 10s;
    }

    # ── Analytics proxy — SLMPlatform metrics ────────────────────────────────
    # /api/agent-perf/* → slm-platform:8080/agent-perf/*
    location /api/agent-perf/ {
        set $slm "${SLM_PLATFORM_URL}";
        rewrite ^/api(/.*)$ $1 break;
        proxy_pass $slm;
        proxy_set_header Host $proxy_host;
        proxy_read_timeout 30s;
    }

    # ── Registry API proxy — eval contracts ──────────────────────────────────
    # /api/registry/* → registry-service:8001/*
    location /api/registry/ {
        set $reg "${REGISTRY_SERVICE_URL}";
        rewrite ^/api/registry(/.*)$ $1 break;
        proxy_pass $reg;
        proxy_set_header Host $proxy_host;
        proxy_read_timeout 30s;
    }

    # ── RegistryService portal — Knowledge Base ──────────────────────────────
    # /registry/* → registry-service:8001/*
    location /registry/ {
        set $reg "${REGISTRY_SERVICE_URL}";
        rewrite ^/registry(/.*)$ $1 break;
        proxy_pass $reg;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_buffering off;
        proxy_read_timeout 30s;
    }
}
